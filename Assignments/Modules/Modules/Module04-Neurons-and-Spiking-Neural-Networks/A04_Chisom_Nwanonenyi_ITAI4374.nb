Cell["\<\
Look at your spike train alongside the sine wave input. The neuron is acting \
as an analog-to-digital converter: it takes a continuous signal and converts \
it into discrete spikes. How well does the spike pattern represent the \
original signal? What information is preserved? What is lost?

When I compared the spike train to the sine wave input, I noticed that the \
spikes\[NonBreakingSpace]follow the overall pattern of the sine wave. The \
neuron fired\[NonBreakingSpace]more spikes when the input current was high\
\[NonBreakingSpace]and fewer or no spikes when the current was low. 
This means the spike pattern still represents the\[NonBreakingSpace]timing \
and strength of the signal.

What is\[NonBreakingSpace]preserved\[NonBreakingSpace]is the general \
information about\[NonBreakingSpace]when the signal is strong and when it is \
weak, because the firing rate increases during the peaks of the sine wave.

What is\[NonBreakingSpace]lost\[NonBreakingSpace]is the exact\
\[NonBreakingSpace]smooth shape of the signal, since the neuron converts the \
continuous input into\[NonBreakingSpace]discrete spikes, so the detailed \
waveform between spikes is not represented.\
\>", "Text",ExpressionUUID->"0991fb2f-29db-4836-9636-b7398e7d9f2c"],

Cell["\<\


\
\>", "Text",ExpressionUUID->"02129187-dd8b-4d82-a8bc-e3b9852eda3f"],

Cell[BoxData[{
 RowBox[{
  RowBox[{
   RowBox[{"ClearAll", "[", 
    RowBox[{
    "V", ",", " ", "t", ",", " ", "lifSolve", ",", " ", "spikeCount", ",", 
     " ", "spikeTimes"}], "]"}], ";"}], "\n", "\n", "\n", "\n", 
  RowBox[{"(*", " ", 
   RowBox[{"Parameters", " ", 
    RowBox[{"(", "yours", ")"}]}], " ", "*)"}]}], "\n", 
 RowBox[{
  RowBox[{"tau", "    ", "=", " ", "0.020"}], ";"}], "\n", 
 RowBox[{
  RowBox[{"Vrest", "  ", "=", " ", 
   RowBox[{"-", "70.0"}]}], ";"}], "\n", 
 RowBox[{
  RowBox[{"Vthresh", "=", " ", 
   RowBox[{"-", "55.0"}]}], ";"}], "\n", 
 RowBox[{
  RowBox[{"Vreset", " ", "=", " ", 
   RowBox[{"-", "75.0"}]}], ";"}], "\n", 
 RowBox[{
  RowBox[{
   RowBox[{"R", "      ", "=", " ", "1.0"}], ";"}], "\n", "\n", 
  RowBox[{"(*", " ", 
   RowBox[{"LIF", " ", "solver", " ", "that", " ", "returns", " ", 
    RowBox[{"{", 
     RowBox[{"Vsol", ",", " ", "spikeTimes"}], "}"}], " ", "for", " ", "any", 
    " ", "input", " ", "function", " ", "and", " ", 
    RowBox[{"threshold", "/", "tau"}]}], " ", "*)"}]}], "\n", 
 RowBox[{
  RowBox[{
   RowBox[{
    RowBox[{"lifSolve", "[", 
     RowBox[{"input_", ",", " ", "tauVal_", ",", " ", "thresh_"}], "]"}], " ",
     ":=", " ", 
    RowBox[{"Module", "[", 
     RowBox[{
      RowBox[{"{", 
       RowBox[{"vsol", ",", " ", "st"}], "}"}], ",", "\n", "  ", 
      RowBox[{
       RowBox[{
        RowBox[{"{", 
         RowBox[{"vsol", ",", " ", "st"}], "}"}], " ", "=", "\n", "    ", 
        RowBox[{"Reap", " ", "@", " ", 
         RowBox[{"NDSolveValue", "[", "\n", "      ", 
          RowBox[{
           RowBox[{"{", "\n", "        ", 
            RowBox[{
             RowBox[{
              RowBox[{"tauVal", "*", 
               RowBox[{
                RowBox[{"V", "'"}], "[", "t", "]"}]}], " ", "==", " ", 
              RowBox[{
               RowBox[{"-", 
                RowBox[{"(", 
                 RowBox[{
                  RowBox[{"V", "[", "t", "]"}], " ", "-", " ", "Vrest"}], 
                 ")"}]}], " ", "+", " ", 
               RowBox[{"R", "*", 
                RowBox[{"input", "[", "t", "]"}]}]}]}], ",", "\n", "        ", 
             RowBox[{
              RowBox[{"V", "[", "0", "]"}], " ", "==", " ", "Vrest"}], ",", 
             "\n", "        ", 
             RowBox[{"WhenEvent", "[", "\n", "          ", 
              RowBox[{
               RowBox[{
                RowBox[{"V", "[", "t", "]"}], " ", "\[GreaterEqual]", " ", 
                "thresh"}], ",", "\n", "          ", 
               RowBox[{"{", 
                RowBox[{
                 RowBox[{
                  RowBox[{"V", "[", "t", "]"}], " ", "\[Rule]", " ", 
                  "Vreset"}], ",", " ", 
                 RowBox[{"Sow", "[", "t", "]"}]}], "}"}], ",", "\n", 
               "          ", " ", "\[Rule]"}], " ", "\n", "        ", "]"}]}],
             "\n", "      ", "}"}], ",", "\n", "      ", "V", ",", " ", 
           RowBox[{"{", 
            RowBox[{"t", ",", " ", "0", ",", " ", "0.5"}], "}"}], ",", "\n", 
           "      ", 
           RowBox[{"MaxStepSize", " ", "\[Rule]", " ", 
            RowBox[{"tauVal", "/", "50"}]}]}], "\n", "    ", "]"}]}]}], ";", 
       "\n", "  ", 
       RowBox[{"st", " ", "=", " ", 
        RowBox[{"If", "[", 
         RowBox[{
          RowBox[{"st", " ", "===", " ", 
           RowBox[{"{", "}"}]}], ",", " ", 
          RowBox[{"{", "}"}], ",", " ", 
          RowBox[{"st", "[", 
           RowBox[{"[", "1", "]"}], "]"}]}], "]"}]}], ";", "\n", "  ", 
       RowBox[{"{", 
        RowBox[{"vsol", ",", " ", "st"}], "}"}]}]}], "\n", "]"}]}], ";"}], 
  "\n", "\n", 
  RowBox[{"(*", " ", 
   RowBox[{"Default", " ", 
    RowBox[{"\[OpenCurlyDoubleQuote]", 
     RowBox[{"dashboard", "-", "like"}], "\[CloseCurlyDoubleQuote]"}], " ", 
    "pulse", " ", 
    RowBox[{"input", ":", " ", 
     RowBox[{"on", " ", "from", " ", "0.05", " ", "to", " ", "0.4"}]}]}], " ",
    "*)"}]}], "\n", 
 RowBox[{
  RowBox[{"IconstAmp", " ", "=", " ", "18.0"}], ";"}], "\n", 
 RowBox[{
  RowBox[{
   RowBox[{"Ipulse", "[", 
    RowBox[{"t_", "?", "NumericQ"}], "]"}], " ", ":=", " ", 
   RowBox[{"If", "[", 
    RowBox[{
     RowBox[{
     "0.05", " ", "\[LessEqual]", " ", "t", " ", "\[LessEqual]", " ", "0.4"}],
      ",", " ", "IconstAmp", ",", " ", "0.0"}], "]"}]}], ";"}]}], "Input",
 CellLabel->
  "In[240]:= ",ExpressionUUID->"fb3bed09-946b-4317-8e06-08b14d1fdda1"],

