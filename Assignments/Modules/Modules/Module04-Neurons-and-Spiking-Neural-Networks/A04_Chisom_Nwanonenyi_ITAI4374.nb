    RowBox[{"{", ",", " ", "}"}]}], ",", "\n", "  ", 
   RowBox[{"PlotLabel", " ", "\[Rule]"}], " ", ",", "\n", "  ", 
   RowBox[{"PlotRange", " ", "\[Rule]", " ", "All"}]}], "\n", "]"}]}], "Input",\
ExpressionUUID->"f82f00ab-f2b4-4d0c-9cb0-b7003e6ea618"],

