      0.005, ControlType -> Manipulator}, {{
       Hold[$CellContext`currentVal$$], 18., "Input Current (nA)"}, 0, 40, 1, 
      ControlType -> Manipulator}}, Typeset`size$$ = Automatic, 
    Typeset`update$$ = 0, Typeset`initDone$$, Typeset`skipInitDone$$ = True, 
