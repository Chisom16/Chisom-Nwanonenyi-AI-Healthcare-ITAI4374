Cell[BoxData[
 RowBox[{
  RowBox[{"(*", " ", 
   RowBox[{"The", " ", "LIF", " ", "differential", " ", 
    RowBox[{"equation", ":"}]}], " ", "*)"}], "\n", 
  RowBox[{"(*", " ", 
   RowBox[{
    RowBox[{"tau", " ", "*", " ", 
     RowBox[{
      RowBox[{"V", "'"}], "[", "t", "]"}]}], " ", "==", " ", 
    RowBox[{
     RowBox[{"-", 
      RowBox[{"(", 
       RowBox[{
        RowBox[{"V", "[", "t", "]"}], " ", "-", " ", "Vrest"}], ")"}]}], " ", 
     "+", " ", 
     RowBox[{"R", " ", "*", " ", 
      RowBox[{"I", "[", "t", "]"}]}]}]}], " ", "*)"}], "\n", 
  RowBox[{"(*", " ", "*)"}], "\n", 
  RowBox[{"(*", " ", 
   RowBox[{"tau", " ", "=", " ", 
    RowBox[{"membrane", " ", "time", " ", "constant", " ", 
     RowBox[{"(", "seconds", ")"}]}]}], " ", "*)"}], "\n", 
  RowBox[{"(*", " ", 
   RowBox[{"Vrest", " ", "=", " ", 
    RowBox[{"resting", " ", "potential", " ", 
     RowBox[{"(", "mV", ")"}]}]}], " ", "*)"}], "\n", 
  RowBox[{"(*", " ", 
   RowBox[{"R", " ", "=", " ", 
    RowBox[{"membrane", " ", "resistance", " ", 
     RowBox[{"(", "MOhm", ")"}]}]}], " ", "*)"}], "\n", 
  RowBox[{"(*", " ", 
   RowBox[{
    RowBox[{"I", "[", "t", "]"}], " ", "=", " ", 
    RowBox[{"input", " ", "current", " ", 
     RowBox[{"(", "nA", ")"}]}]}], " ", "*)"}], "\n", 
  RowBox[{"(*", " ", "*)"}], "\n", 
  RowBox[{"(*", " ", 
   RowBox[{
    RowBox[{
     RowBox[{"When", " ", 
      RowBox[{"V", "[", "t", "]"}]}], " ", ">=", " ", "Vthresh"}], ",", " ", 
    RowBox[{"neuron", " ", "spikes", " ", "and", " ", "resets"}]}], " ", 
   "*)"}]}]], "Input",ExpressionUUID->"a1aedbb1-e528-4938-be89-a86bdb4e4975"],

Cell[BoxData[
 RowBox[{
  RowBox[{"(*", " ", 
   RowBox[{"===", "===", "===", "===", " ", 
    RowBox[{"Neuron", " ", "Parameters"}], " ", "===", "===", "===", "==="}], 
   " ", "*)"}], "\n", 
  RowBox[{
   RowBox[{
    RowBox[{"tau", " ", "=", " ", "0.020"}], ";"}], " ", 
   RowBox[{"(*", " ", 
    RowBox[{"Membrane", " ", "time", " ", 
     RowBox[{"constant", ":", " ", 
      RowBox[{"20", " ", "ms"}]}]}], " ", "*)"}], "\n", 
   RowBox[{
    RowBox[{"Vrest", " ", "=", " ", 
     RowBox[{"-", "70.0"}]}], ";"}], " ", 
   RowBox[{"(*", " ", 
    RowBox[{"Resting", " ", "potential", " ", "in", " ", "mV"}], " ", "*)"}], 
   "\n", 
   RowBox[{
    RowBox[{"Vthresh", " ", "=", " ", 
     RowBox[{"-", "55.0"}]}], ";"}], " ", 
   RowBox[{"(*", " ", 
    RowBox[{"Spike", " ", "threshold", " ", "in", " ", "mV"}], " ", "*)"}], "\n", 
   RowBox[{
    RowBox[{"Vreset", " ", "=", " ", 
     RowBox[{"-", "75.0"}]}], ";"}], " ", 
   RowBox[{"(*", " ", 
    RowBox[{"Reset", " ", "potential", " ", "after", " ", "spike"}], " ", 
    "*)"}], "\n", 
   RowBox[{
    RowBox[{"R", " ", "=", " ", "1.0"}], ";"}], " ", 
   RowBox[{"(*", " ", 
    RowBox[{
     RowBox[{"Membrane", " ", "resistance"}], ",", " ", "normalized"}], " ", 
    "*)"}], "\n", 
   RowBox[{"(*", " ", 
    RowBox[{"===", "===", "===", "===", " ", 
     RowBox[{"Input", " ", "Current"}], " ", "===", "===", "===", "==="}], 
    " ", "*)"}], "\n", 
   RowBox[{"(*", " ", 
    RowBox[{
     RowBox[{
     "Constant", " ", "current", " ", "that", " ", "turns", " ", "on", " ", 
      "at", " ", "t"}], "=", 
     RowBox[{
      RowBox[{"0.05", " ", "and", " ", "off", " ", "at", " ", "t"}], "=", 
      "0.4"}]}], " ", "*)"}], "\n", 
   RowBox[{
    RowBox[{
     RowBox[{"Iinput", "[", "t_", "]"}], " ", ":=", " ", 
