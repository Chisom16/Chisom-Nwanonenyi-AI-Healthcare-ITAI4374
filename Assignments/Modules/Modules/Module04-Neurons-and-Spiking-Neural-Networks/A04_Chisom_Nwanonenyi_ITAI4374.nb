        Typeset`keyframeList$$}, "Body" :> 
      Module[{$CellContext`vsol$, $CellContext`sc$, $CellContext`st$, \
$CellContext`iFunc$, $CellContext`Vinf$, $CellContext`tCross$}, \
$CellContext`iFunc$[
           PatternTest[
            Pattern[$CellContext`t$, 
             Blank[]], NumericQ]] := 
         If[0.05 <= $CellContext`t$ <= 0.4, $CellContext`currentVal$$, 
           0.]; {$CellContext`vsol$, $CellContext`st$} = Reap[
           
           NDSolveValue[{$CellContext`tauVal$$ 
              Derivative[
