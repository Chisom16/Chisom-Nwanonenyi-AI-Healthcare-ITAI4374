  RowBox[{
   RowBox[{
    RowBox[{"ClearAll", "[", 
     RowBox[{
     "V", ",", " ", "t", ",", " ", "iFunc", ",", " ", "spikeCountForCurrent", 
      ",", " ", "fiData"}], "]"}], ";"}], "\n", "\n", "\n", "\n", 
   RowBox[{"(*", " ", 
    RowBox[{"Helper", ":", " ", 
     RowBox[{
     "return", " ", "spike", " ", "count", " ", "for", " ", "a", " ", "given",
       " ", "constant", " ", "current", " ", "amplitude", " ", "Icurr"}]}], 
    " ", "*)"}], "\n", 
   RowBox[{
    RowBox[{
     RowBox[{"spikeCountForCurrent", "[", 
      RowBox[{"Icurr_", "?", "NumericQ"}], "]"}], " ", ":=", " ", 
     RowBox[{"Module", "[", 
      RowBox[{
       RowBox[{"{", 
        RowBox[{"vsol", ",", " ", "st"}], "}"}], ",", "\n", "  ", 
       RowBox[{
        RowBox[{
         RowBox[{"iFunc", "[", 
          RowBox[{"t_", "?", "NumericQ"}], "]"}], " ", ":=", " ", 
         RowBox[{"If", "[", 
          RowBox[{
           RowBox[{
           "0.05", " ", "\[LessEqual]", " ", "t", " ", "\[LessEqual]", " ", 
            "0.4"}], ",", " ", "Icurr", ",", " ", "0.0"}], "]"}]}], ";", "\n",
         "\n", "  ", 
        RowBox[{
         RowBox[{"{", 
          RowBox[{"vsol", ",", " ", "st"}], "}"}], " ", "=", "\n", "    ", 
         RowBox[{"Reap", " ", "@", " ", 
          RowBox[{"NDSolveValue", "[", "\n", "      ", 
           RowBox[{
            RowBox[{"{", "\n", "        ", 
             RowBox[{
              RowBox[{
               RowBox[{"tau", "*", 
                RowBox[{
                 RowBox[{"V", "'"}], "[", "t", "]"}]}], " ", "==", " ", 
               RowBox[{
                RowBox[{"-", 
                 RowBox[{"(", 
                  RowBox[{
                   RowBox[{"V", "[", "t", "]"}], " ", "-", " ", "Vrest"}], 
                  ")"}]}], " ", "+", " ", 
                RowBox[{"R", "*", 
                 RowBox[{"iFunc", "[", "t", "]"}]}]}]}], ",", "\n", 
              "        ", 
              RowBox[{
               RowBox[{"V", "[", "0", "]"}], " ", "==", " ", "Vrest"}], ",", 
              "\n", "        ", 
              RowBox[{"WhenEvent", "[", "\n", "          ", 
               RowBox[{
                RowBox[{
                 RowBox[{"V", "[", "t", "]"}], " ", "\[GreaterEqual]", " ", 
                 "Vthresh"}], ",", "\n", "          ", 
                RowBox[{"{", 
                 RowBox[{
                  RowBox[{
                   RowBox[{"V", "[", "t", "]"}], " ", "\[Rule]", " ", 
                   "Vreset"}], ",", " ", 
                  RowBox[{"Sow", "[", "t", "]"}]}], "}"}], ",", "\n", 
                "          ", " ", "\[Rule]"}], " ", "\n", "        ", 
               "]"}]}], "\n", "      ", "}"}], ",", "\n", "      ", "V", ",", 
            " ", 
            RowBox[{"{", 
             RowBox[{"t", ",", " ", "0", ",", " ", "0.5"}], "}"}], ",", "\n", 
            "      ", 
            RowBox[{"MaxStepSize", " ", "\[Rule]", " ", 
             RowBox[{"tau", "/", "50"}]}]}], "\n", "    ", "]"}]}]}], ";", 
        "\n", "\n", "  ", 
        RowBox[{"st", " ", "=", " ", 
         RowBox[{"If", "[", 
          RowBox[{
           RowBox[{"st", " ", "===", " ", 
            RowBox[{"{", "}"}]}], ",", " ", 
           RowBox[{"{", "}"}], ",", " ", 
           RowBox[{"st", "[", 
            RowBox[{"[", "1", "]"}], "]"}]}], "]"}]}], ";", "\n", "  ", 
        RowBox[{"Length", "[", "st", "]"}]}]}], "\n", "]"}]}], ";"}], "\n", 
   "\n", "\n", "\n", 
   RowBox[{"(*", " ", 
    RowBox[{"Create", " ", 
     RowBox[{"{", 
      RowBox[{"current", ",", " ", "spikeCount"}], "}"}], " ", "pairs"}], " ",
     "*)"}], "\n", 
   RowBox[{
    RowBox[{"fiData", " ", "=", " ", 
     RowBox[{"Table", "[", "\n", "  ", 
      RowBox[{
       RowBox[{"{", 
        RowBox[{"Icurr", ",", " ", 
         RowBox[{"spikeCountForCurrent", "[", "Icurr", "]"}]}], "}"}], ",", 
       "\n", "  ", 
       RowBox[{"{", 
        RowBox[{"Icurr", ",", " ", "0", ",", " ", "35", ",", " ", "1"}], 
        "}"}]}], "\n", "]"}]}], ";"}], "\n", "\n", "\n", "\n", 
   RowBox[{"(*", " ", 
    RowBox[{
