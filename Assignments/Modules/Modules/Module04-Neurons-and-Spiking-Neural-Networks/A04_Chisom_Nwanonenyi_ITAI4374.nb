Cell["\<\
With\[NonBreakingSpace]smaller\[NonBreakingSpace]\[Tau]\[NonBreakingSpace](0.\
010):\[NonBreakingSpace]V\[NonBreakingSpace]rises/decays\[NonBreakingSpace]\
faster\[NonBreakingSpace](steeper exponential), \
usually\[NonBreakingSpace]more spikes.

With\[NonBreakingSpace]larger\[NonBreakingSpace]\[Tau]\[NonBreakingSpace](0.\
050):\[NonBreakingSpace]V\[NonBreakingSpace]changes\[NonBreakingSpace]more \
slowly\[NonBreakingSpace](gentler exponential), \
usually\[NonBreakingSpace]fewer spikes\[NonBreakingSpace]and a \
\[OpenCurlyDoubleQuote]smoother/slower\[CloseCurlyDoubleQuote] looking curve.\
\
\>", "Text",ExpressionUUID->"000fcb54-1014-42f8-8e0c-844f81136568"],

Cell["\<\

Experiment 3: Noisy input (repeat several runs)\
\>", "Text",ExpressionUUID->"7d32cf3d-0f0b-4a4d-97e8-6c2564297f11"],

Cell[CellGroupData[{

Cell[BoxData[{
 RowBox[{
  RowBox[{
   RowBox[{"ClearAll", "[", "makeNoisyInput", "]"}], ";"}], "\n", "\n", 
  "\n"}], "\n", 
 RowBox[{
  RowBox[{
   RowBox[{
    RowBox[{"makeNoisyInput", "[", "seed_Integer", "]"}], " ", ":=", " ", 
    RowBox[{"Module", "[", 
     RowBox[{
      RowBox[{"{", 
       RowBox[{
        RowBox[{"dt", " ", "=", " ", "0.001"}], ",", " ", "ts", ",", " ", 
        "vals", ",", " ", "f"}], "}"}], ",", "\n", "  ", 
      RowBox[{
       RowBox[{"SeedRandom", "[", "seed", "]"}], ";", "\n", "  ", 
       RowBox[{"ts", " ", "=", " ", 
        RowBox[{"Range", "[", 
         RowBox[{"0", ",", " ", "0.5", ",", " ", "dt"}], "]"}]}], ";", "\n", 
       "  ", 
       RowBox[{"vals", " ", "=", " ", 
        RowBox[{"18.0", " ", "+", " ", 
         RowBox[{"RandomReal", "[", 
          RowBox[{
           RowBox[{"{", 
            RowBox[{
             RowBox[{"-", "8"}], ",", " ", "8"}], "}"}], ",", " ", 
           RowBox[{"Length", "[", "ts", "]"}]}], "]"}]}]}], ";", "\n", "  ", 
       RowBox[{"f", " ", "=", " ", 
        RowBox[{"Interpolation", "[", 
         RowBox[{
          RowBox[{"Transpose", "[", 
           RowBox[{"{", 
            RowBox[{"ts", ",", " ", "vals"}], "}"}], "]"}], ",", " ", 
          RowBox[{"InterpolationOrder", " ", "\[Rule]", " ", "0"}]}], "]"}]}],
        ";", " ", 
       RowBox[{"(*", " ", 
        RowBox[{"piecewise", "-", 
         RowBox[{"constant", " ", "noise"}]}], " ", "*)"}], "\n", "  ", 
       RowBox[{"Function", "[", 
        RowBox[{
         RowBox[{"{", "x", "}"}], ",", " ", 
         RowBox[{"f", "[", "x", "]"}]}], "]"}]}]}], "\n", "]"}]}], ";"}], 
  "\n", "\n", "\n"}], "\n", 
 RowBox[{
  RowBox[{"runs", " ", "=", " ", "5"}], ";"}], "\n", 
 RowBox[{
  RowBox[{
   RowBox[{"seeds", " ", "=", " ", 
    RowBox[{"Range", "[", 
     RowBox[{"100", ",", " ", 
      RowBox[{"100", " ", "+", " ", "runs", " ", "-", " ", "1"}]}], "]"}]}], 
   ";"}], "\n"}], "\n", 
 RowBox[{
  RowBox[{
   RowBox[{"noisyResults", " ", "=", " ", 
    RowBox[{"Table", "[", "\n", "  ", 
     RowBox[{
      RowBox[{"Module", "[", 
       RowBox[{
        RowBox[{"{", 
         RowBox[{"Inoise", ",", " ", "vsol", ",", " ", "st"}], "}"}], ",", 
        "\n", "    ", 
        RowBox[{
         RowBox[{"Inoise", " ", "=", " ", 
          RowBox[{"makeNoisyInput", "[", "sd", "]"}]}], ";", "\n", "    ", 
         RowBox[{
          RowBox[{"{", 
           RowBox[{"vsol", ",", " ", "st"}], "}"}], " ", "=", " ", 
          RowBox[{"lifSolve", "[", 
           RowBox[{
            RowBox[{"Function", "[", 
             RowBox[{
              RowBox[{"{", "x", "}"}], ",", " ", 
              RowBox[{"Inoise", "[", "x", "]"}]}], "]"}], ",", " ", "tau", ",",
             " ", "Vthresh"}], "]"}]}], ";", "\n", "    ", 
         RowBox[{"{", 
          RowBox[{"sd", ",", " ", 
           RowBox[{"Length", "[", "st", "]"}], ",", " ", "st"}], "}"}]}]}], 
       "\n", "  ", "]"}], ",", "\n", "  ", 
      RowBox[{"{", 
       RowBox[{"sd", ",", " ", "seeds"}], "}"}]}], "\n", "]"}]}], ";"}], "\n",
   "\n", 
  RowBox[{"(*", " ", 
   RowBox[{"Show", " ", "spike", " ", "counts", " ", "per", " ", "run"}], " ",
    "*)"}]}], "\n", 
 RowBox[{
  RowBox[{"Grid", "[", "\n", "  ", 
   RowBox[{
    RowBox[{"Prepend", "[", 
     RowBox[{
      RowBox[{"noisyResults", "[", 
       RowBox[{"[", 
        RowBox[{"All", ",", " ", 
         RowBox[{"{", 
          RowBox[{"1", ",", " ", "2"}], "}"}]}], "]"}], "]"}], ",", " ", 
      RowBox[{"{", ",", " ", "}"}]}], "]"}], ",", "\n", "  ", 
    RowBox[{"Frame", " ", "\[Rule]", " ", "All"}]}], "\n", "]"}], "\n", "\n", 
  
  RowBox[{"(*", " ", 
   RowBox[{"Optional", ":", " ", 
    RowBox[{"raster", "-", 
     RowBox[{"like", " ", "spike", " ", "time", " ", "plot"}]}]}], " ", 
   "*)"}]}], "\n", 
 RowBox[{"ListPlot", "[", "\n", "  ", 
  RowBox[{
   RowBox[{"Table", "[", 
    RowBox[{
     RowBox[{"Thread", "[", 
      RowBox[{"{", 
       RowBox[{
        RowBox[{"noisyResults", "[", 
         RowBox[{"[", 
          RowBox[{"k", ",", " ", "3"}], "]"}], "]"}], ",", " ", "k"}], "}"}], 
      "]"}], ",", " ", 
     RowBox[{"{", 
      RowBox[{"k", ",", " ", "1", ",", " ", "runs"}], "}"}]}], "]"}], ",", 
   "\n", "  ", 
   RowBox[{"PlotStyle", " ", "\[Rule]", " ", 
    RowBox[{"PointSize", "[", "0.015", "]"}]}], ",", "\n", "  ", 
   RowBox[{"AxesLabel", " ", "\[Rule]", " ", 
    RowBox[{"{", ",", " ", "}"}]}], ",", "\n", "  ", 
   RowBox[{"PlotLabel", " ", "\[Rule]"}], " ", ",", "\n", "  ", 
   RowBox[{"PlotRange", " ", "\[Rule]", " ", 
    RowBox[{"{", 
     RowBox[{
      RowBox[{"{", 
       RowBox[{"0", ",", " ", "0.5"}], "}"}], ",", " ", 
      RowBox[{"{", 
       RowBox[{"0.5", ",", " ", 
        RowBox[{"runs", " ", "+", " ", "0.5"}]}], "}"}]}], "}"}]}]}], "\n", 
  "]"}]}], "Input",ExpressionUUID->"ffd2e2b9-b55d-447b-82fb-5de2a388e368"],

