          PlotRange -> All, AxesLabel -> {"t (s)", "V (mV)"}, PlotLabel -> 
          StringForm["Spikes: ``", $CellContext`sc$], 
          Epilog -> {Red, Dashed, 
            
            InfiniteLine[{{0, $CellContext`thresh$$}, {
              1, $CellContext`thresh$$}}], Blue, 
            PointSize[0.015], 
            Point[
             Transpose[{$CellContext`st$, 
               ConstantArray[$CellContext`thresh$$, $CellContext`sc$]}]]}]], 
      "Specifications" :> {{{$CellContext`thresh$$, -55., 
          "Threshold (mV)"}, -65, -45, 
         1}, {{$CellContext`tauVal$$, 0.02, "Time Constant (s)"}, 0.005, 0.1, 
