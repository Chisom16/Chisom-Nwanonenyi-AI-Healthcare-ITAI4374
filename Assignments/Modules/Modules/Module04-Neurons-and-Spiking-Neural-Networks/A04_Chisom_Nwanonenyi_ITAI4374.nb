-($CellContext`V[$CellContext`t] - $CellContext`Vrest) + $CellContext`R \
$CellContext`iFunc$[$CellContext`t], $CellContext`V[0] == $CellContext`Vrest, 
             
             
             WhenEvent[$CellContext`V[$CellContext`t] >= \
$CellContext`thresh$$, {$CellContext`V[$CellContext`t] -> $CellContext`Vreset, 
               Sow[$CellContext`t]}, "LocationMethod" -> 
              "LinearInterpolation"]}, $CellContext`V, {$CellContext`t, 0, 
