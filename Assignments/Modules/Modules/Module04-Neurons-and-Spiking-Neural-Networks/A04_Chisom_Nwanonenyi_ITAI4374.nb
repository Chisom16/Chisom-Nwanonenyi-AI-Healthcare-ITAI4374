Cell[BoxData["\<\"Parameters defined.\"\>"], "Print",ExpressionUUID->"1e8c9d6a-dba5-4c89-98ea-9c8140ceb537"],

Cell["\<\
1. The input current is defined as a function of time using If[]. In plain \
English, what does Iinput[t]
return at t = 0.03? At t = 0.2? At t = 0.5?

Values of\[NonBreakingSpace]Iinput[t]:

t = 0.03 \[RightArrow] 0.0\[NonBreakingSpace](before the current turns on)

t = 0.2 \[RightArrow] 18.0\[NonBreakingSpace](current is on between 0.05 and \
0.4)

t = 0.5 \[RightArrow] 0.0\[NonBreakingSpace](after the current turns off)

2. Why do we use := (delayed assignment) for Iinput instead of = (immediate \
assignment)?

Why use\[NonBreakingSpace]:=\[NonBreakingSpace]instead of\[NonBreakingSpace]=:

:=\[NonBreakingSpace](delayed assignment) evaluates the expression\
\[NonBreakingSpace]each time the function is called, so the result depends on \
the value of\[NonBreakingSpace]t.

=\[NonBreakingSpace](immediate assignment) would evaluate the expression\
\[NonBreakingSpace]once when defined, which could give incorrect behavior for \
a function that depends on\[NonBreakingSpace]t.\
\>", "Text",ExpressionUUID->"43f8fa37-1bba-439d-ba72-6acea150293c"],

Cell[CellGroupData[{

Cell[BoxData[{
 RowBox[{
  RowBox[{
   RowBox[{"ClearAll", "[", 
    RowBox[{
    "V", ",", " ", "t", ",", " ", "Iinput", ",", " ", "sol", ",", " ", 
     "spikeTimes", ",", " ", "spikeCount"}], "]"}], ";"}], "\n", "\n", "\n", 
  "\n", 
  RowBox[{"(*", " ", 
   RowBox[{"Your", " ", "parameters"}], " ", "*)"}]}], "\n", 
 RowBox[{
  RowBox[{
   RowBox[{"tau", "    ", "=", " ", "0.020"}], ";"}], "   ", 
  RowBox[{"(*", " ", "s", " ", "*)"}]}], "\n", 
 RowBox[{
  RowBox[{
   RowBox[{"Vrest", "  ", "=", " ", 
    RowBox[{"-", "70.0"}]}], ";"}], "   ", 
  RowBox[{"(*", " ", "mV", " ", "*)"}]}], "\n", 
 RowBox[{
  RowBox[{
   RowBox[{"Vthresh", "=", " ", 
    RowBox[{"-", "55.0"}]}], ";"}], "   ", 
  RowBox[{"(*", " ", "mV", " ", "*)"}]}], "\n", 
 RowBox[{
  RowBox[{
   RowBox[{"Vreset", " ", "=", " ", 
    RowBox[{"-", "75.0"}]}], ";"}], "   ", 
  RowBox[{"(*", " ", "mV", " ", "*)"}]}], "\n", 
 RowBox[{
  RowBox[{
   RowBox[{"R", "      ", "=", " ", "1.0"}], ";"}], "\n"}], "\n", 
 RowBox[{
  RowBox[{
   RowBox[{"I0", " ", "=", " ", "20.0"}], ";"}], "\n", "\n"}], "\n", 
 RowBox[{
  RowBox[{
   RowBox[{
    RowBox[{"Iinput", "[", 
     RowBox[{"t_", "?", "NumericQ"}], "]"}], " ", ":=", " ", "I0"}], ";"}], 
  "\n", "\n", 
  RowBox[{"(*", " ", 
   RowBox[{"Sanity", " ", "check"}], " ", "*)"}]}], "\n", 
 RowBox[{
  RowBox[{"Vinf", " ", "=", " ", 
   RowBox[{"Vrest", " ", "+", " ", 
    RowBox[{"R", "*", 
     RowBox[{"Iinput", "[", "0", "]"}]}]}]}], ";"}], "\n", 
 RowBox[{
  RowBox[{"tCross", " ", "=", " ", 
   RowBox[{
    RowBox[{"-", "tau"}], "*", 
    RowBox[{"Log", "[", 
     RowBox[{
      RowBox[{"(", 
       RowBox[{"Vthresh", " ", "-", " ", "Vinf"}], ")"}], "/", 
      RowBox[{"(", 
       RowBox[{"Vrest", " ", "-", " ", "Vinf"}], ")"}]}], "]"}]}]}], ";"}], "\n", 
 RowBox[{
  RowBox[{"Print", "[", 
   RowBox[{"\"\<Vinf = \>\"", ",", " ", "Vinf", ",", 
    " ", "\"\< (threshold = \>\"", ",", " ", "Vthresh", ",", 
    " ", "\"\<)\>\""}], "]"}], ";"}], "\n", 
 RowBox[{
  RowBox[{
   RowBox[{"Print", "[", 
    RowBox[{"\"\<(No-reset) first crossing time \[TildeTilde] \>\"", ",", " ", 
     RowBox[{"N", "[", "tCross", "]"}], ",", " ", "\"\< s\>\""}], "]"}], 
   ";"}], "\n"}], "\n", 
 RowBox[{
  RowBox[{
   RowBox[{
    RowBox[{"{", 
     RowBox[{"sol", ",", " ", "spikeTimes"}], "}"}], " ", "=", "\n", "  ", 
    RowBox[{"Reap", " ", "@", " ", 
     RowBox[{"NDSolveValue", "[", "\n", "    ", 
      RowBox[{
       RowBox[{"{", "\n", "      ", 
        RowBox[{
         RowBox[{
          RowBox[{"tau", "*", 
           RowBox[{
            RowBox[{"V", "'"}], "[", "t", "]"}]}], " ", "==", " ", 
          RowBox[{
           RowBox[{"-", 
            RowBox[{"(", 
             RowBox[{
              RowBox[{"V", "[", "t", "]"}], " ", "-", " ", "Vrest"}], ")"}]}],
            " ", "+", " ", 
           RowBox[{"R", "*", 
            RowBox[{"Iinput", "[", "t", "]"}]}]}]}], ",", "\n", "      ", 
         RowBox[{
          RowBox[{"V", "[", "0", "]"}], " ", "==", " ", "Vrest"}], ",", "\n", 
         "      ", 
         RowBox[{"WhenEvent", "[", "\n", "        ", 
          RowBox[{
           RowBox[{
            RowBox[{"V", "[", "t", "]"}], " ", "\[GreaterEqual]", " ", 
            "Vthresh"}], ",", "\n", "        ", 
           RowBox[{"{", 
            RowBox[{
             RowBox[{
              RowBox[{"V", "[", "t", "]"}], " ", "\[Rule]", " ", "Vreset"}], ",",
              " ", 
             RowBox[{"Sow", "[", "t", "]"}]}], "}"}], ",", "\n", "        ", 
           
           RowBox[{"\"\<LocationMethod\>\"", " ", "\[Rule]", 
            " ", "\"\<LinearInterpolation\>\""}]}], "\n", "      ", "]"}]}], 
        "\n", "    ", "}"}], ",", "\n", "    ", "V", ",", " ", 
       RowBox[{"{", 
        RowBox[{"t", ",", " ", "0", ",", " ", "0.5"}], "}"}], ",", "\n", 
       "    ", 
       RowBox[{"MaxStepSize", " ", "\[Rule]", " ", 
        RowBox[{"tau", "/", "50"}]}]}], "\n", "  ", "]"}]}]}], ";"}], 
  "\n"}], "\n", 
 RowBox[{
  RowBox[{"spikeTimes", " ", "=", " ", 
   RowBox[{"If", "[", 
    RowBox[{
     RowBox[{"spikeTimes", " ", "===", " ", 
      RowBox[{"{", "}"}]}], ",", " ", 
     RowBox[{"{", "}"}], ",", " ", 
     RowBox[{"spikeTimes", "[", 
      RowBox[{"[", "1", "]"}], "]"}]}], "]"}]}], ";"}], "\n", 
 RowBox[{
  RowBox[{
   RowBox[{"spikeCount", " ", "=", " ", 
    RowBox[{"Length", "[", "spikeTimes", "]"}]}], ";"}], "\n"}], "\n", 
 RowBox[{
  RowBox[{"Print", "[", 
   RowBox[{"\"\<Neuron fired \>\"", ",", " ", "spikeCount", ",", 
    " ", "\"\< spikes\>\""}], "]"}], ";"}], "\n", 
 RowBox[{
  RowBox[{"Print", "[", 
   RowBox[{"\"\<Spike times: \>\"", ",", " ", "spikeTimes"}], "]"}], 
  ";"}]}], "Input",ExpressionUUID->"f456127e-b806-4531-bf20-79f623d8f651"],

